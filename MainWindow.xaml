<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TaskManagerUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskManagerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d"
    Title="Task Manager">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="LeftCompact"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneTitle="Task Manager"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="ms-appx:///Styles/MainWindow.TypographyAndCards.xaml" />
                    <ResourceDictionary Source="ms-appx:///Styles/MainWindow.Controls.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Processes" Tag="Processes">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE770;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Charts" Tag="Charts">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="GPU" Tag="GPU">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE91B;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Details" Tag="Details">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9D2;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Settings" Tag="Settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <ScrollViewer x:Name="ProcessesView"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Disabled"
                          VerticalScrollMode="Auto">
                <Grid Padding="20,16,20,16" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Processes" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Monitor CPU, memory, disk, and network activity in one view."
                                       Style="{StaticResource PageSubtitleStyle}" />
                            <TextBlock Text="{x:Bind LastUpdatedText, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE770;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="System" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind SystemCpuText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                    <TextBlock Text="{x:Bind CpuTemperatureText, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorCautionBrush}">
                                    <FontIcon Glyph="&#xEEA0;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Memory" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind MemoryUsageText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                    <TextBlock Text="{x:Bind RamFrequencyText, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorSuccessBrush}">
                                    <FontIcon Glyph="&#xE701;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Network" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind NetworkUsageText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorAttentionBrush}">
                                    <FontIcon Glyph="&#xEDA2;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Disk" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind DiskActivitySummary, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                    <TextBlock Text="{x:Bind DiskReadWriteText, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind DiskNamesText, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorCriticalBrush}">
                                    <FontIcon Glyph="&#xEEA1;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Processes" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind ProcessCountSummary, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE721;" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="1"
                                         PlaceholderText="Search by process name or PID"
                                         FontSize="14"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         CornerRadius="0">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlElevationBorderFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                    </TextBox.Resources>
                                </TextBox>
                            </Grid>
                        </Border>
                    </Border>

                    <Grid Grid.Row="3" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="12,10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="Name">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Name" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('Name', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="PID">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="PID" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('PID', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="CPU">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="CPU" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('CPU', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="Memory">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Memory" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('Memory', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="DiskRead">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Read/s" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('DiskRead', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="5" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="DiskWrite">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Write/s" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('DiskWrite', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="6" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="NetRecv">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Net Recv" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('NetRecv', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="7" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="NetSent">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Net Sent" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('NetSent', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}" Padding="0">
                            <Grid>
                                <ListView x:Name="ProcessesListView"
                                          SelectionMode="Extended"
                                          ShowsScrollingPlaceholders="True"
                                          KeyDown="ProcessesListView_KeyDown"
                                          Background="Transparent"
                                          BorderThickness="0">
                                    <ListView.ItemContainerTransitions>
                                        <TransitionCollection>
                                            <AddDeleteThemeTransition />
                                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                                        </TransitionCollection>
                                    </ListView.ItemContainerTransitions>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ProcessRowViewModel">
                                            <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="40" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.ColumnSpan="9" Background="{ThemeResource AccentFillColorSecondaryBrush}" Opacity="{x:Bind CellOpacity1, Mode=OneWay}" Margin="-8,-8" CornerRadius="8" />

                                                <Grid Grid.Column="0" Margin="{x:Bind NameMargin, Mode=OneWay}" ColumnSpacing="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ClickMode="Press"
                                                            Visibility="{x:Bind HasChildrenVisibility, Mode=OneWay}"
                                                            Command="{x:Bind ToggleExpandCommand}">
                                                        <FontIcon Glyph="{x:Bind ExpandIcon, Mode=OneWay}" FontSize="12" />
                                                    </Button>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="14" />
                                                </Grid>
                                                <TextBlock Grid.Column="1" Text="{x:Bind PidText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind CpuText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Column="3" Text="{x:Bind MemoryText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Column="4" Text="{x:Bind DiskReadText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="5" Text="{x:Bind DiskWriteText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="6" Text="{x:Bind NetRecvText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="7" Text="{x:Bind NetSentText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <Button Grid.Column="8" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" 
                                                        ToolTipService.ToolTip="Kill Process" Command="{x:Bind KillCommand}">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <ListView.ItemContainerStyle>
                                        <StaticResource ResourceKey="ProcessListItemStyle" />
                                    </ListView.ItemContainerStyle>
                                </ListView>

                                <TextBlock Text="No processes match your search."
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind NoResultsVisibility, Mode=OneWay}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <ScrollViewer x:Name="ChartsView" Visibility="Collapsed">
                <StackPanel Padding="20,16,20,16" Spacing="14">
                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Performance Charts" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="System history overview." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{x:Bind ChartsList, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:MetricChartViewModel">
                                <Border Style="{StaticResource SectionCardStyle}" Height="300" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" Margin="0,0,0,10" FontSize="14" />
                                        <lvc:CartesianChart Grid.Row="1" Series="{x:Bind Series}" XAxes="{x:Bind XAxes}" YAxes="{x:Bind YAxes}" LegendPosition="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="GpuView" Padding="20,16,20,16" RowSpacing="14" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="GPU Processes" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Dedicated and integrated GPU engine activity." Style="{StaticResource PageSubtitleStyle}" />
                        <TextBlock Text="Fetching some GPU may require Administrator mode."
                                   Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Dedicated GPU" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind GpuStatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="0" Margin="0,0,0,20">
                    <Grid>
                        <ListView x:Name="DedicatedGpuProcessesListView"
                                  SelectionMode="Extended"
                                  ShowsScrollingPlaceholders="True"
                                  KeyDown="GpuProcessesListView_KeyDown"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:GpuProcessViewModel">
                                    <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind PidText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind TemperatureText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <StaticResource ResourceKey="ProcessListItemStyle" />
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <TextBlock Text="No processes detected on dedicated GPU."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind NoGpuResultsVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Integrated GPU" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind IntegratedGpuStatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}" Padding="0">
                    <Grid>
                        <ListView x:Name="IntegratedGpuProcessesListView"
                                  SelectionMode="Extended"
                                  ShowsScrollingPlaceholders="True"
                                  KeyDown="GpuProcessesListView_KeyDown"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:GpuProcessViewModel">
                                    <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind PidText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind TemperatureText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <StaticResource ResourceKey="ProcessListItemStyle" />
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <TextBlock Text="No processes detected on integrated GPU."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind NoIntegratedGpuResultsVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer x:Name="DetailsView" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Padding="20,16,20,16" Spacing="14">
                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="12" Background="{ThemeResource AccentFillColorSecondaryBrush}" VerticalAlignment="Top">
                                <FontIcon Glyph="&#xE9D2;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="CPU Core Details" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text="Per-core usage and frequency in real time."
                                           Style="{StaticResource PageSubtitleStyle}" />
                                <TextBlock Text="{x:Bind ProcessorNameText, Mode=OneWay}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ProcessorTopologyText, Mode=OneWay}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ProcessorCacheText, Mode=OneWay}"
                                           Style="{StaticResource PageSubtitleStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource DetailHeaderIconBadgeStyle}">
                                    <FontIcon Glyph="&#xE9D9;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="System Metrics" Style="{StaticResource DetailSectionTitleStyle}" />
                                    <TextBlock Text="Live counters for CPU-side system activity." Style="{StaticResource PageSubtitleStyle}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE81E;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Temperature" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="Temperature" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind CpuTemperatureText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xEA86;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Context Switches" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="ContextSwitches" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind ContextSwitchesText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE7E8;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Interrupts" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="Interrupts" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind InterruptsText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE9CE;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="System Calls" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="SystemCalls" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind SyscallsText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE823;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="CPU Queue" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="CpuQueue" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind CpuQueueText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE9D9;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="CPU Time Breakdown" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="CpuTimeBreakdown" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind CpuTimeBreakdownText, Mode=OneWay}" FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE82E;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Idle Time" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="IdleTime" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind CpuIdleTimeText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailMetricTileStyle}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource DetailHeaderIconBadgeStyle}" Width="32" Height="32" CornerRadius="9">
                                            <FontIcon Glyph="&#xE7FC;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="CPU Parking" Style="{StaticResource DetailMetricLabelStyle}" />
                                                <Button Width="20" Height="20" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Tag="CpuParking" Click="ShowMetricTeachingTip">
                                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind CpuParkingText, Mode=OneWay}" Style="{StaticResource DetailMetricValueStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                            <TeachingTip x:Name="DetailsMetricTeachingTip"
                                         IsLightDismissEnabled="True"
                                         PreferredPlacement="Bottom" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource DetailHeaderIconBadgeStyle}">
                                    <FontIcon Glyph="&#xE950;" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="CPU Cores" Style="{StaticResource DetailSectionTitleStyle}" VerticalAlignment="Center" />
                            </Grid>
                        <ListView x:Name="CpuCoreListView"
                                  Loaded="CpuCoreListView_Loaded"
                                  SizeChanged="CpuCoreListView_SizeChanged"
                                  ItemsSource="{x:Bind CpuCoreMetrics, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  Background="Transparent"
                                  Padding="3,0"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="270" ItemHeight="124" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:CpuCoreMetricViewModel">
                                    <Border Style="{StaticResource DetailTileStyle}">
                                        <Grid RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind CoreLabel, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                    <TextBlock Text="Frequency:" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    <TextBlock Text="{x:Bind FrequencyText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Grid.Row="1" Spacing="2">
                                                <TextBlock Text="Logical processor" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{x:Bind CoreName, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" MaxLines="2" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="Usage:" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{x:Bind UsageText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="12" Background="{ThemeResource AccentFillColorSecondaryBrush}" VerticalAlignment="Top">
                                <FontIcon Glyph="&#xEDA2;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Storage Disks" Style="{StaticResource DetailSectionTitleStyle}" />
                                <TextBlock Text="Local drive capacity and activity." Style="{StaticResource PageSubtitleStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Padding="14">
                        <ListView ItemsSource="{x:Bind DisksList, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  Background="Transparent"
                                  Padding="3,0"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="320" ItemHeight="132" HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:DiskViewModel">
                                    <Border Style="{StaticResource DetailTileStyle}">
                                        <Grid RowSpacing="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind DiskType}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{x:Bind Model}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="2" Text="{x:Bind CapacityText, Mode=OneWay}" FontSize="12" />
                                            <TextBlock Grid.Row="3" Text="{x:Bind ActivityText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SettingsView" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Padding="20,16,20,16" Spacing="14">
                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Appearance Settings" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Customize system backdrop material and acrylic parameters."
                                       Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Backdrop material" Style="{StaticResource DetailMetricLabelStyle}" />
                                <ComboBox x:Name="BackdropModeCombo"
                                          SelectionChanged="BackdropModeCombo_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                                    <ComboBoxItem Content="Mica" Tag="Mica" />
                                    <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="AcrylicSettingsPanel" Spacing="12">
                                <ToggleSwitch x:Name="AcrylicThinToggle"
                                              Header="Use thin acrylic"
                                              IsOn="True"
                                              Toggled="AcrylicThinToggle_Toggled" />

                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="TintOpacityLabel" Text="Tint opacity: 0.74" Style="{StaticResource DetailMetricLabelStyle}" />
                                    <Slider x:Name="TintOpacitySlider"
                                            Minimum="0.30"
                                            Maximum="1.00"
                                            StepFrequency="0.01"
                                            Value="0.74"
                                            ValueChanged="TintOpacitySlider_ValueChanged" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="LuminosityOpacityLabel" Text="Luminosity opacity: 0.84" Style="{StaticResource DetailMetricLabelStyle}" />
                                    <Slider x:Name="LuminosityOpacitySlider"
                                            Minimum="0.30"
                                            Maximum="1.00"
                                            StepFrequency="0.01"
                                            Value="0.84"
                                            ValueChanged="LuminosityOpacitySlider_ValueChanged" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </NavigationView>
</Window>
