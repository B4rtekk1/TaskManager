<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TaskManagerUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskManagerUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d"
    Title="Task Manager">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="LeftCompact"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneTitle="Task Manager"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.Resources>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,0" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>

            <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CardLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="CardValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="HeaderCommandButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="ProcessListItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Processes" Tag="Processes">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE770;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Charts" Tag="Charts">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="GPU" Tag="GPU">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE91B;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <ScrollViewer x:Name="ProcessesView"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Disabled"
                          VerticalScrollMode="Auto">
                <Grid Padding="20,16,20,16" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Processes" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Monitor CPU, memory, disk, and network activity in one view."
                                       Style="{StaticResource PageSubtitleStyle}" />
                            <TextBlock Text="{x:Bind LastUpdatedText, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE770;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="System" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind SystemCpuText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorCautionBrush}">
                                    <FontIcon Glyph="&#xEEA0;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Memory" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind MemoryUsageText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorSuccessBrush}">
                                    <FontIcon Glyph="&#xE701;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Network" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind NetworkUsageText, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="10" Background="{ThemeResource SystemFillColorCriticalBrush}">
                                    <FontIcon Glyph="&#xEEA1;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Processes" Style="{StaticResource CardLabelStyle}" />
                                    <TextBlock Text="{x:Bind ProcessCountSummary, Mode=OneWay}" Style="{StaticResource CardValueStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE721;" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="1"
                                         PlaceholderText="Search by process name or PID"
                                         FontSize="14"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         CornerRadius="0">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlElevationBorderFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                    </TextBox.Resources>
                                </TextBox>
                            </Grid>
                        </Border>

                        <Button Grid.Column="1"
                                Click="ClearSearch_Click"
                                ToolTipService.ToolTip="Clear search"
                                Padding="10"
                                MinWidth="40"
                                Height="42"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <FontIcon Glyph="&#xE711;" />
                        </Button>
                    </Grid>
                    </Border>

                    <Grid Grid.Row="3" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="12,10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="Name">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Name" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('Name', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="PID">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="PID" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('PID', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="CPU">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="CPU" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('CPU', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="Memory">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Memory" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('Memory', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="DiskRead">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Read/s" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('DiskRead', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="5" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="DiskWrite">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Write/s" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('DiskWrite', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="6" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="NetRecv">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Net Recv" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('NetRecv', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="7" Style="{StaticResource HeaderCommandButtonStyle}" Command="{x:Bind SortCommand}" CommandParameter="NetSent">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Net Sent" />
                                        <FontIcon Glyph="{x:Bind GetSortIcon('NetSent', SortColumn, SortAscending), Mode=OneWay}" FontSize="10" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}" Padding="0">
                            <Grid>
                                <ListView x:Name="ProcessesListView"
                                          SelectionMode="Extended"
                                          ShowsScrollingPlaceholders="True"
                                          KeyDown="ProcessesListView_KeyDown"
                                          Background="Transparent"
                                          BorderThickness="0">
                                    <ListView.ItemContainerTransitions>
                                        <TransitionCollection>
                                            <AddDeleteThemeTransition />
                                            <RepositionThemeTransition IsStaggeringEnabled="False" />
                                        </TransitionCollection>
                                    </ListView.ItemContainerTransitions>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ProcessRowViewModel">
                                            <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="40" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.ColumnSpan="9" Background="{ThemeResource AccentFillColorSecondaryBrush}" Opacity="{x:Bind CellOpacity1, Mode=OneWay}" Margin="-8,-8" CornerRadius="8" />

                                                <Grid Grid.Column="0" Margin="{x:Bind NameMargin, Mode=OneWay}" ColumnSpacing="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ClickMode="Press"
                                                            Visibility="{x:Bind HasChildrenVisibility, Mode=OneWay}"
                                                            Command="{x:Bind ToggleExpandCommand}">
                                                        <FontIcon Glyph="{x:Bind ExpandIcon, Mode=OneWay}" FontSize="12" />
                                                    </Button>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="14" />
                                                </Grid>
                                                <TextBlock Grid.Column="1" Text="{x:Bind PidText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind CpuText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Column="3" Text="{x:Bind MemoryText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Column="4" Text="{x:Bind DiskReadText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="5" Text="{x:Bind DiskWriteText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="6" Text="{x:Bind NetRecvText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Grid.Column="7" Text="{x:Bind NetSentText, Mode=OneWay}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <Button Grid.Column="8" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" 
                                                        ToolTipService.ToolTip="Kill Process" Command="{x:Bind KillCommand}">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <ListView.ItemContainerStyle>
                                        <StaticResource ResourceKey="ProcessListItemStyle" />
                                    </ListView.ItemContainerStyle>
                                </ListView>

                                <TextBlock Text="No processes match your search."
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind NoResultsVisibility, Mode=OneWay}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <ScrollViewer x:Name="ChartsView" Visibility="Collapsed">
                <StackPanel Padding="20,16,20,16" Spacing="14">
                    <Border Style="{StaticResource SectionCardStyle}" Padding="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Performance Charts" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="System history overview." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{x:Bind ChartsList, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:MetricChartViewModel">
                                <Border Style="{StaticResource SectionCardStyle}" Height="300" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" Margin="0,0,0,10" FontSize="14" />
                                        <lvc:CartesianChart Grid.Row="1" Series="{x:Bind Series}" XAxes="{x:Bind XAxes}" YAxes="{x:Bind YAxes}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="GpuView" Padding="20,16,20,16" RowSpacing="14" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="GPU Processes" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Dedicated and integrated GPU engine activity." Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Dedicated GPU" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind GpuStatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="0" Margin="0,0,0,20">
                    <Grid>
                        <ListView x:Name="DedicatedGpuProcessesListView"
                                  SelectionMode="Extended"
                                  ShowsScrollingPlaceholders="True"
                                  KeyDown="GpuProcessesListView_KeyDown"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:GpuProcessViewModel">
                                    <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind PidText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind TemperatureText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <StaticResource ResourceKey="ProcessListItemStyle" />
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <TextBlock Text="No processes detected on dedicated GPU."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind NoGpuResultsVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Integrated GPU" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind IntegratedGpuStatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}" Padding="0">
                    <Grid>
                        <ListView x:Name="IntegratedGpuProcessesListView"
                                  SelectionMode="Extended"
                                  ShowsScrollingPlaceholders="True"
                                  KeyDown="GpuProcessesListView_KeyDown"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:GpuProcessViewModel">
                                    <Grid ColumnSpacing="12" Padding="12,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind PidText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind TemperatureText}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <StaticResource ResourceKey="ProcessListItemStyle" />
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <TextBlock Text="No processes detected on integrated GPU."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind NoIntegratedGpuResultsVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </NavigationView>
</Window>
